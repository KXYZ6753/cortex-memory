# !! Copy this file to `.env` and fill in your own values.

# Postgres connection string. The values below match docker-compose.yml's
# ! defaults and work for local development as-is.
DATABASE_URL="postgresql://user:password@localhost:5432/cortex-memory"
DEBUG_LOGGING=false

# --- Gmail / IMAP connector (src/connectors/connector-imap.js) ---
# Host and port default to Gmail if omitted.
# App Password for gmail: https://myaccount.google.com/apppasswords Alternatively: (Google account → Security → App passwords)
IMAP_HOST="imap.gmail.com"
IMAP_PORT="993"
IMAP_USER="you@gmail.com"
IMAP_PASSWORD="your-app-password" # <- IMAP Password, NOT your login password. Read above

# --- Ollama Configuration Paramters ---
# You may leave them as they are currently, or change it based on your device and needs
LLM_PROCESSING_ENABLED=true
EMBEDDING_PROCESSING_ENABLED=true
OLLAMA_MODEL="qwen3.5:2b"
OLLAMA_DEBUG=false
OLLAMA_MAX_ATTEMPTS=3
OLLAMA_TIMEOUT_MS=60000
OLLAMA_TOTAL_TIMEOUT_MS=150000
OLLAMA_EMBED_TIMEOUT_MS=30000
