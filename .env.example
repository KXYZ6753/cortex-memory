# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
# `.env` is gitignored — your real secrets never get committed.

# Postgres connection string. The values below match docker-compose.yml's
# defaults and work for local development as-is.
DATABASE_URL="postgresql://user:password@localhost:5432/cortex-memory"
DEBUG_LOGGING=true

# --- Gmail / IMAP connector (src/connectors/connector-imap.js) ---
# Host and port default to Gmail if omitted. For Gmail, IMAP_PASSWORD must be an
# App Password (Google account → Security → App passwords), not your login password.
IMAP_HOST="imap.gmail.com"
IMAP_PORT="993"
IMAP_USER="you@gmail.com"
IMAP_PASSWORD="your-app-password"
